{
  "name": "bazi-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test tests/*.test.cjs",
    "check": "npm run typecheck && npm run test && npm run build",
    "audit:release": "npm audit --omit=dev --audit-level=high",
    "sync:classics": "node scripts/sync-ditiansui.mjs && node scripts/sync-lixu.mjs && node scripts/sync-qiongtong.mjs && node scripts/split-classics.mjs",
    "split:classics": "node scripts/split-classics.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.23.0",
    "lunar-javascript": "^1.7.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~6.0.2"
  }
}
